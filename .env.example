# =============================================================================
# crypto-streaming-pipeline — environment configuration
#
# Usage:
#   cp .env.example .env
#   Fill in all values marked REQUIRED before running any services or scripts.
#
# Never commit .env to version control.
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=crypto_user
POSTGRES_PASSWORD=                        # REQUIRED — minimum 12 characters
POSTGRES_DB=crypto_pipeline

# Connection string for scripts and application code.
#
# ⚠️  TWO DIFFERENT HOSTS depending on context:
#
#   Dev container / host machine:
#     DATABASE_URL=postgresql://crypto_user:yourpassword@host.docker.internal:5432/crypto_pipeline
#
#   Docker services on crypto_net (producer, consumer):
#     DATABASE_URL=postgresql://crypto_user:yourpassword@crypto_postgres:5432/crypto_pipeline
#
# Replace yourpassword with your POSTGRES_PASSWORD value.
DATABASE_URL=postgresql://crypto_user:@host.docker.internal:5432/crypto_pipeline

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=crypto_rabbit
RABBITMQ_DEFAULT_PASS=                    # REQUIRED — minimum 20 characters (Erlang cookie requirement)

# Connection string for scripts and application code.
#
# ⚠️  TWO DIFFERENT HOSTS depending on context:
#
#   Dev container / host machine:
#     AMQP_URL=amqp://crypto_rabbit:yourpassword@host.docker.internal:5672/
#
#   Docker services on crypto_net (producer, consumer):
#     AMQP_URL=amqp://crypto_rabbit:yourpassword@crypto_rabbitmq:5672/
#
# Replace yourpassword with your RABBITMQ_DEFAULT_PASS value.
AMQP_URL=amqp://crypto_rabbit:@host.docker.internal:5672/

# ── RabbitMQ Topology ─────────────────────────────────────────────────────────
RABBITMQ_EXCHANGE=crypto.trades.exchange
RABBITMQ_QUEUE=crypto.trades.queue
RABBITMQ_DLQ=crypto.trades.dlq
RABBITMQ_ROUTING_KEY=trades.raw

# ── Coinbase WebSocket ────────────────────────────────────────────────────────
WEBSOCKET_URL=wss://advanced-trade-ws.coinbase.com/v1
PRODUCT_ID=BTC-USD

# ── Producer ──────────────────────────────────────────────────────────────────
PRODUCER_METRICS_PORT=8000

# ── Consumer ──────────────────────────────────────────────────────────────────
CONSUMER_PREFETCH=100
CONSUMER_METRICS_PORT=8001
BATCH_SIZE=200
BATCH_TIMEOUT_MS=2000

# ── dbt ───────────────────────────────────────────────────────────────────────
PG_HOST=host.docker.internal
PG_PORT=5432
PG_USER=crypto_user
PG_PASSWORD=                              # Same as POSTGRES_PASSWORD
PG_DB=crypto_pipeline
DBT_PROFILES_DIR=/workspaces/crypto-streaming-lakehouse/dbt

# ── Airflow ───────────────────────────────────────────────────────────────────
# Generate FERNET_KEY with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_FERNET_KEY=                       # REQUIRED — encrypts sensitive data in Airflow DB
AIRFLOW_SECRET_KEY=                       # REQUIRED — secures Airflow webserver sessions
AIRFLOW_ADMIN_PASSWORD=                   # REQUIRED — admin UI login password

# ── Metabase API (used by Airflow sync task) ──────────────────────────────────
METABASE_URL=http://metabase:3000
METABASE_ADMIN_EMAIL=                     # REQUIRED — Metabase admin email
METABASE_ADMIN_PASSWORD=                  # REQUIRED — Metabase admin password
METABASE_DATABASE_ID=2                    # Database ID of Crypto Lakehouse in Metabase
