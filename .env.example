# =============================================================================
# crypto-streaming-pipeline — environment configuration
# Copy this file to .env and fill in all values marked REQUIRED.
# Never commit .env to version control.
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=crypto_user
# REQUIRED — no default. Choose a strong password.
POSTGRES_PASSWORD=postgres_password
POSTGRES_DB=crypto_pipeline

# SQLAlchemy / psycopg2 connection string.
# Replace <password> with your POSTGRES_PASSWORD value.
# Host must be the container name when connecting from inside Docker (crypto_postgres).
# Use localhost:5432 when connecting from the host machine or dev container.
DATABASE_URL=postgresql://crypto_user:<password>@crypto_postgres:5432/crypto_pipeline

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=crypto_rabbit
# REQUIRED — no default. Choose a strong password.
# REQUIRED: minimum 20 characters (Erlang cookie requirement)
RABBITMQ_DEFAULT_PASS=crypto_rabbit_pass_2024

# pika connection string.
# Use host.docker.internal when running scripts from inside the dev container.
# Use crypto_rabbitmq when connecting from other Docker services on crypto_net.
AMQP_URL=amqp://crypto_rabbit:<password>@host.docker.internal:5672/

# ── RabbitMQ Topology ─────────────────────────────────────────────────────────
RABBITMQ_EXCHANGE=crypto.trades.exchange
RABBITMQ_QUEUE=crypto.trades.queue
RABBITMQ_DLQ=crypto.trades.dlq
RABBITMQ_ROUTING_KEY=trades.raw

# ── Coinbase WebSocket ────────────────────────────────────────────────────────
WEBSOCKET_URL=wss://advanced-trade-ws.coinbase.com/v1
PRODUCT_ID=BTC-USD

# ── Producer ──────────────────────────────────────────────────────────────────
PRODUCER_METRICS_PORT=8000

# ── Consumer ──────────────────────────────────────────────────────────────────
CONSUMER_PREFETCH=100
CONSUMER_METRICS_PORT=8001
BATCH_SIZE=200
BATCH_TIMEOUT_MS=2000
